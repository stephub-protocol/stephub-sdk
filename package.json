{
  "name": "@stephubprotocol/partner-sdk",
  "version": "0.2.2",
  "description": "TypeScript SDK for the StepHub Partners API — integrate physical activity data into your app",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "stephub",
    "steps",
    "fitness",
    "health",
    "api",
    "sdk",
    "proof-of-physical-work"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/stephub-protocol/stephub-sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
